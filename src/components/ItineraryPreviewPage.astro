---
import { ArrowRight, CalendarDays, CloudDownload, LockKeyhole, Route, Ticket } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import type { City } from "@data/cities";
import { checkoutUrl } from "@data/site";

type Props = {
  city: City;
  days: 2 | 3;
};

const { city, days } = Astro.props;
const dayLabel = `${days}-Day`;
const otherHref = days === 2 ? city.threeDayHref : city.twoDayHref;
const otherLabel = days === 2 ? "Preview the 3-day plan" : "Preview the 2-day plan";
const previewDays =
  days === 2
    ? [
        { title: "Day 1: First-time highlights", text: `Use the free ${city.name} 1-day route as the base, with tighter timing, better food notes, and clearer backup options in the full pack.` },
        { title: "Day 2: Slower second layer", text: `Add a second route around ${city.mustSee}, with a lower-stress pace and fewer cross-city detours.` },
      ]
    : [
        { title: "Day 1: First-time highlights", text: `Start with the key ${city.name} landmarks and keep transport simple.` },
        { title: "Day 2: Deeper city route", text: "Use a second day for neighborhoods, food, and attractions that are hard to fit into a single route." },
        { title: "Day 3: Flexible expansion", text: "Choose a slower day, nature add-on, museum route, or backup plan depending on weather and energy." },
      ];

const included = [
  "Complete hour-by-hour route in the paid PDF",
  "Booking reminders and passport-name checks",
  "Food and rest stops that avoid unnecessary detours",
  "Backup route for weather, closures, sold-out tickets, or low energy",
];
---

<BaseLayout
  title={`${city.name} ${dayLabel} Itinerary Preview`}
  description={`Preview the ${city.name} ${dayLabel.toLowerCase()} itinerary structure for first-time visitors. The full route, printable PDF, booking reminders, and backup plans are in the current pack.`}
>
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><a href={city.href}>Cities</a><span>/</span><span>{city.name} {dayLabel} Preview</span>
      </nav>
      <p class="eyebrow">Preview only</p>
      <h1>{city.name} {dayLabel} Itinerary Preview</h1>
      <p class="lead">
        This page shows the outline and free boundary. The full {dayLabel.toLowerCase()} timeline, printable PDF,
        booking reminders, food notes, and backup routes are part of the current paid pack.
      </p>
      <div class="trust-row">
        <span class="pill"><LockKeyhole size={16} /> Full route locked</span>
        <span class="pill"><CalendarDays size={16} /> {city.recommendedDays}</span>
        <span class="pill"><Ticket size={16} /> Booking reminders included in paid pack</span>
      </div>
      <div class="inline-actions">
        <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">Unlock all current packs - $9.90</a>
        <a class="button button-secondary" href={city.freeGuideHref}>Read the free 1-day guide</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container timeline">
      {previewDays.map((day) => (
        <article class="timeline-item">
          <div>
            <h2>{day.title}</h2>
            <p class="muted">{day.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight">
    <div class="container content-grid">
      <article class="content-card">
        <Route size={32} />
        <h2>What you can see for free</h2>
        <p class="muted">A route outline, the city context, and a clear explanation of what is inside the full pack.</p>
      </article>
      <article class="content-card">
        <CloudDownload size={32} />
        <h2>What the full pack adds</h2>
        <ul class="clean-list">
          {included.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="content-card">
        <LockKeyhole size={32} />
        <h2>Current pack boundary</h2>
        <p class="muted">The paid pack includes the current files available at checkout. It is a one-time purchase, not a subscription.</p>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container paper-card unlock-panel">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Compare this preview with the free route.</h2>
        <p class="muted">
          Start with the free 1-day guide if you are still evaluating the style. Unlock the current pack when you want the
          complete multi-day PDFs and setup notes.
        </p>
      </div>
      <div class="setup-card">
        <h3>{city.name} route links</h3>
        <ul class="clean-list">
          <li><a class="text-link" href={city.href}>City overview <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href={city.freeGuideHref}>Free 1-day guide <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href={otherHref}>{otherLabel} <ArrowRight size={16} /></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
