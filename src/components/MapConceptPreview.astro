---
import { ArrowRight } from "@lucide/astro";
import { cities } from "@data/cities";

type Variant = "a" | "b" | "c";

type Props = {
  variant: Variant;
};

type CityVisual = {
  x: number;
  y: number;
  mapX: number;
  mapY: number;
  side: "left" | "right";
  icon: "temple" | "skyline" | "wall" | "panda" | "karst" | "pillars";
  cue: string;
  label: string;
};

const { variant } = Astro.props;

const concepts = {
  a: {
    eyebrow: "Concept A",
    title: "3D Light China Travel Map",
    description:
      "A larger isometric-style map for first-time visitors, with glowing city pins and landmark badges for quick route selection.",
    badge: "3D light / isometric",
    note: "Best when the homepage needs a premium visual centerpiece.",
    mapTitle: "Stylized isometric China travel map",
  },
  b: {
    eyebrow: "Concept B",
    title: "Illustrated China Travel Map",
    description:
      "A warm illustrated direction using red, jade, rice paper, fine gold lines, and restrained Chinese travel motifs.",
    badge: "Chinese aesthetic / illustrated",
    note: "Best when the brand should feel more rooted in China travel.",
    mapTitle: "Illustrated China travel map with cultural accents",
  },
  c: {
    eyebrow: "Concept C",
    title: "Modern Minimal Travel Map",
    description:
      "A clean product-style map that prioritizes clickable city labels, short decision cues, and a strong mobile fallback.",
    badge: "Modern minimal / conversion-first",
    note: "Best when clarity, SEO visitors, and mobile usability are the priority.",
    mapTitle: "Modern minimal China city entry map",
  },
} satisfies Record<Variant, {
  eyebrow: string;
  title: string;
  description: string;
  badge: string;
  note: string;
  mapTitle: string;
}>;

const cityVisuals: Record<string, CityVisual> = {
  beijing: {
    x: 60,
    y: 23,
    mapX: 500,
    mapY: 172,
    side: "right",
    icon: "temple",
    cue: "Imperial history",
    label: "Temple roof",
  },
  shanghai: {
    x: 73,
    y: 44,
    mapX: 606,
    mapY: 292,
    side: "left",
    icon: "skyline",
    cue: "Skyline and river",
    label: "Modern skyline",
  },
  xian: {
    x: 50,
    y: 40,
    mapX: 412,
    mapY: 270,
    side: "right",
    icon: "wall",
    cue: "Ancient capital",
    label: "City wall",
  },
  chengdu: {
    x: 42,
    y: 56,
    mapX: 346,
    mapY: 368,
    side: "left",
    icon: "panda",
    cue: "Food and pandas",
    label: "Panda and tea",
  },
  zhangjiajie: {
    x: 59,
    y: 62,
    mapX: 488,
    mapY: 402,
    side: "right",
    icon: "pillars",
    cue: "Pillar mountains",
    label: "Dramatic nature",
  },
  "guilin-yangshuo": {
    x: 55,
    y: 74,
    mapX: 456,
    mapY: 474,
    side: "left",
    icon: "karst",
    cue: "Karst river scenery",
    label: "Karst peaks",
  },
};

const concept = concepts[variant];
const cityItems = cities.map((city) => ({
  ...city,
  ...cityVisuals[city.id],
}));

const chinaShape =
  "M192 168 C238 112 314 92 376 116 C425 82 502 100 535 156 C596 158 655 203 664 264 C722 298 725 375 674 409 C661 475 601 513 535 495 C486 540 408 530 372 475 C314 486 259 454 244 399 C183 380 146 319 171 261 C142 229 151 190 192 168 Z";
const coastShape =
  "M520 156 C569 163 621 199 643 249 C656 279 696 304 688 349 C681 390 635 416 621 458";
---

<section class={`map-concept map-concept--${variant}`} aria-labelledby={`map-concept-${variant}-title`}>
  <div class="container">
    <div class="map-concept__hero">
      <div class="map-concept__copy">
        <p class="eyebrow">{concept.eyebrow}</p>
        <h1 id={`map-concept-${variant}-title`}>{concept.title}</h1>
        <p class="lead">{concept.description}</p>
      </div>
      <aside class="map-concept__note" aria-label="Concept summary">
        <strong>{concept.badge}</strong>
        <p>{concept.note}</p>
      </aside>
    </div>

    <div class="concept-map-shell">
      <div class="concept-map-stage" aria-label="Clickable China travel city map">
        <svg class="concept-map-art" viewBox="0 0 820 600" role="img" aria-labelledby={`map-art-${variant}-title`}>
          <title id={`map-art-${variant}-title`}>{concept.mapTitle}</title>
          <defs>
            <linearGradient id={`land-${variant}`} x1="170" x2="680" y1="120" y2="520" gradientUnits="userSpaceOnUse">
              <stop offset="0" />
              <stop offset="1" />
            </linearGradient>
            <filter id={`soft-shadow-${variant}`} x="-20%" y="-20%" width="140%" height="150%">
              <feDropShadow dx="0" dy="18" stdDeviation="16" flood-color="#261b12" flood-opacity="0.16" />
            </filter>
          </defs>

          <rect class="concept-map-art__backdrop" x="0" y="0" width="820" height="600" rx="34" />

          {variant === "b" && (
            <g class="concept-map-art__brush" aria-hidden="true">
              <path d="M92 130 C132 95 172 94 210 128" />
              <path d="M590 88 C632 62 682 66 721 101" />
              <path d="M116 502 C160 458 205 458 250 501" />
              <path d="M642 492 C672 456 711 456 744 489" />
              <path d="M84 248 C119 226 154 226 189 248" />
            </g>
          )}

          {variant === "c" && (
            <g class="concept-map-art__grid" aria-hidden="true">
              <path d="M86 170 H738" />
              <path d="M86 290 H738" />
              <path d="M86 410 H738" />
              <path d="M220 80 V530" />
              <path d="M410 80 V530" />
              <path d="M600 80 V530" />
            </g>
          )}

          <g class="concept-map-art__body" filter={`url(#soft-shadow-${variant})`}>
            {variant === "a" && <path class="concept-map-art__extrude" d={chinaShape} />}
            <path class="concept-map-art__land" d={chinaShape} />
            <path class="concept-map-art__coast" d={coastShape} />
            <path class="concept-map-art__inner-line" d="M275 240 C350 210 405 230 456 273 C506 315 552 327 617 312" />
            <path class="concept-map-art__inner-line" d="M270 358 C331 330 389 344 432 388 C466 424 510 438 565 420" />
          </g>

          <g class="concept-map-art__routes" aria-hidden="true">
            {cityItems.map((city) => (
              <path class={`concept-map-art__route concept-map-art__route--${city.id}`} d={`M410 316 L ${city.mapX} ${city.mapY}`} />
            ))}
          </g>

          <g class="concept-map-art__dots" aria-hidden="true">
            {cityItems.map((city) => (
              <circle class="concept-map-art__dot" cx={city.mapX} cy={city.mapY} r="5" />
            ))}
          </g>
        </svg>

        <div class="concept-pin-layer">
          {cityItems.map((city) => (
            <a
              class={`concept-pin concept-pin--${city.side} concept-pin--${city.id}`}
              href={city.href}
              data-analytics-event="city_click"
              style={`--x: ${city.x}%; --y: ${city.y}%; --city-color: ${city.color};`}
              aria-label={`Open ${city.name} city guide`}
            >
              <span class="concept-pin__marker" aria-hidden="true">
                <svg viewBox="0 0 40 40">
                  <circle class="concept-pin__marker-glow" cx="20" cy="20" r="18" />
                  <circle class="concept-pin__marker-disc" cx="20" cy="20" r="14" />
                  {city.icon === "temple" && (
                    <g>
                      <path d="M10 18 L20 10 L30 18" />
                      <path d="M13 18 H27" />
                      <path d="M15 21 H25" />
                      <path d="M16 21 V29 M24 21 V29" />
                    </g>
                  )}
                  {city.icon === "skyline" && (
                    <g>
                      <path d="M11 29 H30" />
                      <path d="M13 29 V20 H17 V29" />
                      <path d="M20 29 V13 H24 V29" />
                      <path d="M27 29 V17 H30 V29" />
                      <path d="M22 9 V13" />
                    </g>
                  )}
                  {city.icon === "wall" && (
                    <g>
                      <path d="M11 28 H30" />
                      <path d="M13 28 V18 H17 V28" />
                      <path d="M17 22 H25 V28" />
                      <path d="M25 28 V16 H29 V28" />
                      <path d="M12 16 H18 M24 14 H30" />
                    </g>
                  )}
                  {city.icon === "panda" && (
                    <g>
                      <circle cx="15" cy="15" r="4" />
                      <circle cx="25" cy="15" r="4" />
                      <circle cx="20" cy="22" r="9" />
                      <path d="M16 21 H17 M23 21 H24" />
                      <path d="M18 25 C20 27 22 27 24 25" />
                    </g>
                  )}
                  {city.icon === "karst" && (
                    <g>
                      <path d="M8 29 C12 20 15 15 18 29" />
                      <path d="M16 29 C21 16 24 13 29 29" />
                      <path d="M10 31 C16 28 23 28 31 31" />
                    </g>
                  )}
                  {city.icon === "pillars" && (
                    <g>
                      <path d="M13 30 V17 C13 14 17 14 17 17 V30" />
                      <path d="M20 30 V12 C20 9 25 9 25 12 V30" />
                      <path d="M28 30 V19 C28 16 31 16 31 19 V30" />
                      <path d="M11 30 H32" />
                    </g>
                  )}
                </svg>
              </span>
              <span class="concept-pin__label">
                <strong>{city.name}</strong>
                <small>{city.cue}</small>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="concept-map-aside" aria-label="City guide fallback links">
        <p class="eyebrow">Clickable city guides</p>
        <h2>Pick a first-trip city.</h2>
        <div class="concept-city-list">
          {cityItems.map((city) => (
            <a
              class="concept-city-card"
              href={city.href}
              data-analytics-event="city_click"
              style={`--city-color: ${city.color};`}
              aria-label={`Open ${city.name} city guide`}
            >
              <span class="concept-city-card__icon" aria-hidden="true">
                <svg viewBox="0 0 40 40">
                  <circle cx="20" cy="20" r="18" />
                  {city.icon === "temple" && (
                    <g>
                      <path d="M10 18 L20 10 L30 18" />
                      <path d="M13 18 H27" />
                      <path d="M15 21 H25" />
                      <path d="M16 21 V29 M24 21 V29" />
                    </g>
                  )}
                  {city.icon === "skyline" && (
                    <g>
                      <path d="M11 29 H30" />
                      <path d="M13 29 V20 H17 V29" />
                      <path d="M20 29 V13 H24 V29" />
                      <path d="M27 29 V17 H30 V29" />
                    </g>
                  )}
                  {city.icon === "wall" && (
                    <g>
                      <path d="M11 28 H30" />
                      <path d="M13 28 V18 H17 V28" />
                      <path d="M17 22 H25 V28" />
                      <path d="M25 28 V16 H29 V28" />
                    </g>
                  )}
                  {city.icon === "panda" && (
                    <g>
                      <circle cx="15" cy="15" r="4" />
                      <circle cx="25" cy="15" r="4" />
                      <circle cx="20" cy="22" r="9" />
                      <path d="M16 21 H17 M23 21 H24" />
                      <path d="M18 25 C20 27 22 27 24 25" />
                    </g>
                  )}
                  {city.icon === "karst" && (
                    <g>
                      <path d="M8 29 C12 20 15 15 18 29" />
                      <path d="M16 29 C21 16 24 13 29 29" />
                      <path d="M10 31 C16 28 23 28 31 31" />
                    </g>
                  )}
                  {city.icon === "pillars" && (
                    <g>
                      <path d="M13 30 V17 C13 14 17 14 17 17 V30" />
                      <path d="M20 30 V12 C20 9 25 9 25 12 V30" />
                      <path d="M28 30 V19 C28 16 31 16 31 19 V30" />
                      <path d="M11 30 H32" />
                    </g>
                  )}
                </svg>
              </span>
              <span>
                <strong>{city.name}</strong>
                <small>{city.label}</small>
              </span>
              <ArrowRight size={18} />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
