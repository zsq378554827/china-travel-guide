---
import { Landmark } from "@lucide/astro";
import { footerLinks, site } from "@data/site";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <a class="brand" href="/" aria-label="China Travel Guide home">
      <span class="brand-mark" aria-hidden="true"><Landmark size={22} stroke-width={2.4} /></span>
      <span>
        <span class="brand-title">{site.name}</span><br />
        <span class="muted">First China Trip Made Simple</span>
      </span>
    </a>
    <nav class="footer-links" aria-label="Footer navigation">
      {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>
