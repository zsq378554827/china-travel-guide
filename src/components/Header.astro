---
import { Landmark } from "@lucide/astro";
import { checkoutUrl, navLinks } from "@data/site";

type Props = {
  ctaLabel?: string;
};

const { ctaLabel = "Unlock - $9.90" } = Astro.props;
const currentPath = Astro.url.pathname;

const isActiveLink = (label: string, href: string) => {
  if (label === "Cities") return currentPath.startsWith("/cities/");
  if (label === "Travel Prep") {
    return (
      currentPath.startsWith("/travel-prep/") ||
      currentPath === "/how-to-pay-in-china/" ||
      currentPath === "/china-travel-checklist/" ||
      currentPath === "/arrival-checklist/"
    );
  }
  if (label === "Arrival Pack") return currentPath === "/unlock/";
  if (href.startsWith("/#")) return currentPath === "/" && Astro.url.hash === href.slice(1);

  return currentPath === href;
};
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="China Travel Guide home">
      <span class="brand-mark" aria-hidden="true"><Landmark size={24} stroke-width={2.4} /></span>
      <span class="brand-copy">
        <span class="brand-title">China Travel Guide</span>
        <span class="brand-tagline">Your First China Trip, Made Simple.</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {navLinks.map((link) => <a class:list={{ "is-active": isActiveLink(link.label, link.href) }} href={link.href}>{link.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">{ctaLabel}</a>
    </div>
  </div>
</header>
