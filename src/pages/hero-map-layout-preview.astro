---
import BaseLayout from "@layouts/BaseLayout.astro";
import HomeHero3D from "@components/home/HomeHero3D.astro";
---

<BaseLayout
  title="Hero Map Layout Preview"
  description="Private preview for tuning the 3D China map hero layout."
  noindex
>
  <div class="hero-layout-preview">
    <HomeHero3D />
  </div>
</BaseLayout>

<style is:global>
  .hero-layout-preview .home-hero {
    background:
      radial-gradient(circle at 82% 88%, rgba(63, 132, 145, 0.12), transparent 30%),
      radial-gradient(circle at 11% 88%, rgba(255, 255, 255, 0.48), transparent 25%),
      linear-gradient(110deg, #f8f0e4 0%, #f6ece1 42%, #eadfce 72%, #dfe9e5 100%);
  }

  .hero-layout-preview .home-hero::before {
    background:
      linear-gradient(
        90deg,
        rgba(255, 250, 240, 0.92) 0%,
        rgba(255, 250, 240, 0.7) 24%,
        rgba(255, 250, 240, 0.18) 44%,
        rgba(255, 250, 240, 0) 66%
      ),
      radial-gradient(circle at 8% 88%, rgba(180, 154, 112, 0.11), transparent 26%);
  }

  .hero-layout-preview .home-hero::after {
    display: none;
  }

  .hero-layout-preview .home-hero__inner::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(
        90deg,
        rgba(255, 250, 240, 0.94) 0%,
        rgba(255, 250, 240, 0.8) 27%,
        rgba(255, 250, 240, 0.22) 43%,
        rgba(255, 250, 240, 0.04) 55%,
        rgba(255, 250, 240, 0) 68%
      );
  }

  .hero-layout-preview .home-hero__copy::before {
    display: none;
  }

  .hero-layout-preview .home-feature-grid {
    max-width: 388px;
  }

  .hero-layout-preview .home-feature-grid__item {
    gap: 6px;
    min-height: 78px;
    padding: 8px 6px;
  }

  .hero-layout-preview .home-feature-grid__item svg {
    width: 25px;
    height: 25px;
  }

  .hero-layout-preview .home-feature-grid__item span {
    font-size: 0.72rem;
  }

  .hero-layout-preview .home-map {
    top: 12px;
    right: -52px;
    width: min(1000px, 67vw);
  }

  .hero-layout-preview .home-map__stage,
  .hero-layout-preview .home-map__stage img {
    filter: none;
    -webkit-mask-image: none;
    mask-image: none;
  }

  .hero-layout-preview .home-map__stage::after {
    display: none;
  }

  .hero-layout-preview .home-value-strip {
    bottom: 24px;
    width: min(940px, calc(100% - 160px));
  }

  .hero-layout-preview .home-value-strip__item {
    min-height: 78px;
    padding: 13px 22px;
  }

  .hero-layout-preview .home-value-strip__icon {
    width: 50px;
    height: 50px;
  }

  .hero-layout-preview .home-value-strip h3 {
    font-size: 1.12rem;
  }

  .hero-layout-preview .home-value-strip p {
    font-size: 0.84rem;
  }

  @media (max-width: 980px) {
    .hero-layout-preview .home-feature-grid {
      max-width: 100%;
    }

    .hero-layout-preview .home-map {
      top: auto;
      right: auto;
      width: 100%;
    }

    .hero-layout-preview .home-value-strip {
      width: min(100% - 44px, 780px);
    }
  }

  @media (max-width: 640px) {
    .hero-layout-preview .home-value-strip {
      width: min(100% - 28px, 560px);
    }
  }
</style>
