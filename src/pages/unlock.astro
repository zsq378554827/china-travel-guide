---
import {
  CalendarDays,
  CircleCheck,
  CloudDownload,
  ClipboardCheck,
  FileText,
  Hotel,
  Languages,
  Landmark,
  MapPinned,
  ShieldCheck,
  Signpost,
  TrainFront,
  Utensils,
} from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import FAQList from "@components/FAQList.astro";
import GuideMockup from "@components/GuideMockup.astro";
import { checkoutUrl } from "@data/site";

const included = [
  {
    title: "6 city pack PDFs",
    text: "Beijing, Shanghai, Xi’an, Chengdu, Zhangjiajie, and Guilin & Yangshuo.",
    Icon: Landmark,
  },
  {
    title: "1 / 2 / 3-day routes",
    text: "A compressed 1-day route, a more comfortable 2-day route, and a fuller 3-day route.",
    Icon: CalendarDays,
  },
  {
    title: "Local food picks",
    text: "Recommended dishes and practical food notes, including addresses in the paid PDFs.",
    Icon: Utensils,
  },
  {
    title: "Transport and ticket notes",
    text: "City transport, attraction booking reminders, and what to bring on entry day.",
    Icon: TrainFront,
  },
  {
    title: "Hotel area notes",
    text: "Where to base yourself and how to choose practical first-trip areas.",
    Icon: Hotel,
  },
  {
    title: "Chinese names and addresses",
    text: "Navigation names and addresses that are easier to show in maps, taxis, and hotels.",
    Icon: Languages,
  },
  {
    title: "Quick backup notes",
    text: "Simple alternatives for weather, sold-out tickets, crowding, delays, or low-energy days.",
    Icon: Signpost,
  },
  {
    title: "Travel Prep Printables",
    text: "Arrival, payment, transport, apps, and emergency checklists for offline use.",
    Icon: ClipboardCheck,
  },
];

const cityPacks = [
  "Beijing City Pack PDF",
  "Shanghai City Pack PDF",
  "Xi’an City Pack PDF",
  "Chengdu City Pack PDF",
  "Zhangjiajie City Pack PDF",
  "Guilin & Yangshuo City Pack PDF",
];

const travelPrepPrintables = [
  "Arrival Checklist PDF",
  "Payment & Internet Checklist PDF",
  "Transport & Tickets Checklist PDF",
  "Travel Apps Checklist PDF",
  "Emergency Help Card PDF",
];

const cityPackStructure = [
  "Quick Route Picker",
  "1-Day Route",
  "2-Day Route",
  "3-Day Route",
  "Local Food Picks",
  "Transport Notes",
  "Attraction Ticket Notes",
  "Hotel Area Notes",
  "Chinese Names & Addresses",
  "Quick Backup Notes",
];

const compareRows = [
  ["City landing pages", "Free", "Included as downloadable city PDFs"],
  ["Free 1-Day Guide pages", "Free online", "Included in each city PDF for offline use"],
  ["2-Day Route", "Preview only", "Complete route included"],
  ["3-Day Route", "Preview only", "Complete route included"],
  ["Local food picks with addresses", "Limited web notes", "Included"],
  ["Transport notes", "Basic web guidance", "Included"],
  ["Attraction ticket notes", "Basic reminders", "Included"],
  ["Hotel area notes", "Limited web notes", "Included"],
  ["Chinese names and addresses", "Limited web notes", "Included"],
  ["Travel Prep Printables", "Articles stay free online", "Checklist PDFs included"],
];

const unlockFaq = [
  {
    question: "Is this a subscription?",
    answer: "No. The Arrival Pack is a one-time purchase for $9.90.",
  },
  {
    question: "Do I buy separate city packs?",
    answer: "No. There is only one paid product. The Arrival Pack includes all six city pack PDFs and the Travel Prep Printables.",
  },
  {
    question: "Can I use the free guides first?",
    answer: "Yes. City landing pages, free 1-day guide pages, and Travel Prep article pages stay free online.",
  },
  {
    question: "Why is the 1-day route also inside the paid PDF?",
    answer: "The free 1-day guide remains online. The paid city PDF also includes the complete 1-day route so buyers can save or print it for offline use.",
  },
  {
    question: "Can I use this offline?",
    answer: "Yes. The paid materials are downloadable PDFs that you can save to your phone or print before your trip.",
  },
  {
    question: "How are files delivered?",
    answer: "After checkout, Gumroad provides access to the downloadable Arrival Pack files.",
  },
  {
    question: "Is this official travel advice?",
    answer: "No. This is an independent travel guide. Always check official government, airline, attraction, and payment provider guidance before you travel.",
  },
];

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Arrival Pack",
  description:
    "Six China city pack PDFs, 1 / 2 / 3-day routes, local food picks, ticket reminders, hotel area notes, Chinese addresses, quick backup notes, and Travel Prep Printables.",
  offers: {
    "@type": "Offer",
    price: "9.90",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  },
};
---

<BaseLayout
  title="Unlock Arrival Pack - $9.90"
  description="Unlock the Arrival Pack to get six city pack PDFs, 1 / 2 / 3-day routes, local food picks, ticket reminders, hotel area notes, Chinese addresses, quick backup notes, and Travel Prep Printables."
  jsonLd={productJsonLd}
  headerCtaLabel="Unlock Pack - $9.90"
>
  <section class="hero purchase-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div>
          <p class="eyebrow">One paid product, no subscription</p>
          <h1>Unlock Arrival Pack - $9.90</h1>
        </div>
        <p class="lead">
          Get 6 city packs, 1 / 2 / 3-day routes, local food picks, ticket reminders, hotel area notes,
          Chinese addresses, travel prep checklists, and downloadable PDFs.
        </p>
        <p class="price">$9.90</p>
        <div class="trust-row" aria-label="Purchase facts">
          <span class="pill"><CircleCheck size={16} /> One-time purchase</span>
          <span class="pill"><ShieldCheck size={16} /> No subscription</span>
          <span class="pill"><CloudDownload size={16} /> Downloadable PDFs</span>
        </div>
        <div class="hero-actions">
          <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">Unlock Arrival Pack - $9.90</a>
          <a class="button button-secondary" href="#included">Preview what is included</a>
        </div>
      </div>
      <GuideMockup />
    </div>
  </section>

  <section class="section-tight" id="included">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">What is included</p>
          <h2>Everything is inside one Arrival Pack.</h2>
        </div>
      </div>
      <div class="icon-grid">
        {included.map((item) => {
          const Icon = item.Icon;
          return (
            <article class="icon-card">
              <Icon size={36} />
              <h3>{item.title}</h3>
              <p class="muted">{item.text}</p>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">City Pack PDFs</p>
          <h2>Download city packs separately after purchase.</h2>
        </div>
      </div>
      <div class="content-grid">
        {cityPacks.map((title) => (
          <article class="content-card">
            <MapPinned size={30} />
            <h3>{title}</h3>
            <p class="muted">Includes the shared city pack structure below.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">City Pack Structure</p>
          <h2>Each city PDF follows the same practical format.</h2>
        </div>
      </div>
      <div class="preview-grid">
        {cityPackStructure.map((title, index) => (
          <article class="preview-card">
            <h3>{index + 1}. {title}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Travel Prep Printables</p>
          <h2>Short offline checklists, not long articles.</h2>
        </div>
      </div>
      <div class="content-grid">
        {travelPrepPrintables.map((title) => (
          <article class="content-card">
            <FileText size={30} />
            <h3>{title}</h3>
            <p class="muted">Designed for quick saving, printing, and offline reference.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Free vs Paid</p>
          <h2>Keep the boundary clear.</h2>
        </div>
      </div>
      <div class="compare-table" role="table" aria-label="Free content compared with the Arrival Pack">
        <div class="compare-row" role="row">
          <div role="columnheader">Content</div>
          <div role="columnheader">Free</div>
          <div role="columnheader" class="highlight">Arrival Pack - $9.90</div>
        </div>
        {compareRows.map((row) => (
          <div class="compare-row" role="row">
            <div role="cell">{row[0]}</div>
            <div role="cell">{row[1]}</div>
            <div role="cell">{row[2]}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">FAQ</p>
          <h2>Frequently asked questions.</h2>
        </div>
      </div>
      <FAQList items={unlockFaq} />
    </div>
  </section>

  <section class="section-tight">
    <div class="container paper-card unlock-panel">
      <div>
        <h2>First-time visitors — get the essentials in one pack.</h2>
        <p class="muted">
          Unlock the Arrival Pack to get city PDFs, 2–3 day routes, food picks, transport notes,
          ticket reminders, hotel area notes, Chinese addresses, and Travel Prep Printables.
        </p>
      </div>
      <div>
        <p class="price">$9.90</p>
        <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">Unlock Arrival Pack - $9.90</a>
        {!import.meta.env.PUBLIC_CHECKOUT_URL && (
          <p id="checkout-note" class="checkout-note" style="margin-top: 16px;">
            Checkout is not connected yet. Configure PUBLIC_CHECKOUT_URL with the Gumroad checkout URL before launch.
          </p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
