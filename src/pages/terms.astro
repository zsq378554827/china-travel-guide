---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Service" description="Terms of service and digital product notes for the China Travel Guide MVP.">
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Terms</span></nav>
      <h1>Terms of Service</h1>
      <p class="lead">Digital product, refund, and travel-advice boundaries must be visible before checkout.</p>
    </div>
  </section>
  <section class="section">
    <div class="container content-grid">
      <article class="content-card">
        <h2>Independent guide</h2>
        <p class="muted">This site is an independent travel guide, not official travel, legal, visa, ticketing, or payment advice.</p>
      </article>
      <article class="content-card">
        <h2>Current packs</h2>
        <p class="muted">Purchases include the current packs shown at checkout. Future content is not included unless explicitly stated.</p>
      </article>
      <article class="content-card">
        <h2>Refund rules</h2>
        <p class="muted">Refund and delivery rules must match the selected checkout provider before launch.</p>
      </article>
    </div>
  </section>
</BaseLayout>
