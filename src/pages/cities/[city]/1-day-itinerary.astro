---

<BaseLayout
  title={`${city.name} 1-Day Itinerary for First-Time Visitors`}
  description={`A free ${city.name} 1-day itinerary for first-time visitors with simple timing, booking reminders, food notes, and backup planning.`}
  headerCtaLabel={isBeijing || isShanghai || isXian || isZhangjiajie || isChengdu || isGuilinYangshuo ? "Unlock Pack - $9.90" : undefined}
>
  {isBeijing ? (
    <div class="beijing-guide">
      <section class="bj-hero" aria-labelledby="beijing-itinerary-title">
        <div class="bj-container bj-hero__inner">
          <div class="bj-hero__copy">
            <p class="bj-eyebrow">FREE 1-DAY GUIDE</p>
            <h1 id="beijing-itinerary-title">Beijing <span class="bj-nowrap">1-Day</span><br />Itinerary</h1>
            <p class="bj-subtitle">Classic Route × Local Food × Practical Tips</p>
            <p class="bj-lead">
              A simple, efficient route for first-time visitors. Experience the best of Beijing in one day.
            </p>
            <div class="bj-stat-row" aria-label="Route summary">
              {beijingStats.map(({ label, value, Icon }) => (
                <div class="bj-stat">
                  <span class="bj-stat__icon" aria-hidden="true"><Icon size={23} /></span>
                  <span>
                    <strong>{label}</strong>
                    <small>{value}</small>
                  </span>
                </div>
              ))}
            </div>
          </div>
          <div class="bj-hero__image">
            <img src="/images/cities/beijing-cover.jpg" alt="Forbidden City rooftops at sunset in Beijing" />
          </div>
        </div>
      </section>

      <section class="bj-container bj-prep-grid" aria-label="Before you go">
        {prepCards.map((card) => {
          const Icon = card.Icon;
          return (
            <article class={`bj-prep-card bj-prep-card--${card.variant}`}>
              <div class="bj-card-heading">
                <span aria-hidden="true"><Icon size={22} /></span>
                <h2>{card.title}</h2>
              </div>
              {card.columns && (
                <div class="bj-booking-columns">
                  {card.columns.map((column) => (
                    <div>
                      <h3>{column.title}</h3>
                      {column.lines.map((line) => <p>{line}</p>)}
                    </div>
                  ))}
                </div>
              )}
              {card.checks && (
                <ul class="bj-check-list">
                  {card.checks.map((item) => (
                    <li><Check size={15} /> {item}</li>
                  ))}
                </ul>
              )}
              {card.highlight && (
                <div class="bj-season">
                  <strong>{card.highlight}</strong>
                  <p>{card.text}</p>
                </div>
              )}
            </article>
          );
        })}
      </section>

      <section class="bj-container bj-main-grid" aria-label="Beijing one-day itinerary details">
        <article class="bj-panel bj-timeline-panel">
          <header class="bj-section-title bj-section-title--center">
            <h2>One-Day Itinerary <span>(Classic Route)</span></h2>
          </header>

          <div class="bj-timeline">
            {beijingStops.map((stop) => {
              const TransportIcon = stop.transport.Icon;
              return (
                <section class="bj-stop">
                  <div class="bj-stop__time">
                    <strong>{stop.time}</strong>
                    <span>-{stop.end}</span>
                  </div>
                  <div class="bj-stop__marker" aria-hidden="true">{stop.number}</div>
                  <div class="bj-stop__content">
                    <h3>{stop.title} {stop.suffix && <span>{stop.suffix}</span>}</h3>
                    {stop.description && <p>{stop.description}</p>}

                    {stop.route && (
                      <div class="bj-route-card">
                        <div class="bj-route-card__heading">
                          <strong>Suggested Route</strong>
                          <span>(Enter from Meridian Gate, Exit at North Gate)</span>
                        </div>
                        <div class="bj-route-card__steps">
                          {routeSteps.map((step, index) => (
                            <>
                              <div class="bj-route-step">
                                <strong>{step.title}</strong>
                              </div>
                              {index < routeSteps.length - 1 && <ArrowRight class="bj-route-arrow" size={15} aria-hidden="true" />}
                            </>
                          ))}
                        </div>
                        <p>
                          <strong>Tip:</strong> Tickets must be booked 1-7 days in advance except special dates. Enter
                          with passport. Arrive at opening time to avoid crowds.
                        </p>
                      </div>
                    )}

                    {stop.options && (
                      <div class="bj-food-grid">
                        {stop.options.map((option) => (
                          <article class="bj-food-card">
                            <img src={option.image} alt={option.alt} width="420" height="300" loading="lazy" decoding="async" />
                            <div>
                              <h4><span>{option.label}</span> {option.title}</h4>
                              {option.lines.map((line) => <p>{line}</p>)}
                            </div>
                          </article>
                        ))}
                      </div>
                    )}
                  </div>
                  <aside class="bj-transport-card">
                    <TransportIcon size={22} />
                    <strong>{stop.transport.mode}</strong>
                    <span>{stop.transport.detail}</span>
                    <small>{stop.transport.time}</small>
                  </aside>
                </section>
              );
            })}
          </div>

          <div class="bj-tip">
            <Info size={18} />
            <p><strong>Tip:</strong> Adjust the time flexibly based on crowds and your energy. Take your time and enjoy your first day in Beijing!</p>
          </div>
        </article>

        <aside class="bj-sidebar">
          <section class="bj-panel bj-side-section">
            <header class="bj-section-title">
              <h2>Where to Stay <span>(Wangfujing / Qianmen Area)</span></h2>
            </header>
            <div class="bj-stack">
              {hotels.map((hotel) => (
                <article class="bj-media-card">
                  <img src={hotel.image} alt={hotel.alt} width="640" height="420" loading="lazy" decoding="async" />
                  <div>
                    <p class="bj-green-label">{hotel.label}</p>
                    <h3>{hotel.name}</h3>
                    <div class="bj-mini-tags">
                      {hotel.tags.map((tag) => <span>{tag}</span>)}
                    </div>
                    <p><strong>Price:</strong> {hotel.price}</p>
                    <p>{hotel.description}</p>
                  </div>
                </article>
              ))}
            </div>
            <p class="bj-note">Prices vary by date. Check before booking.</p>
          </section>

          <section class="bj-panel bj-side-section">
            <header class="bj-section-title">
              <h2>From Airport to Hotel</h2>
            </header>
            <div class="bj-stack">
              {airportTransfers.map((airport) => (
                <article class="bj-media-card bj-media-card--airport">
                  <img src={airport.image} alt={airport.alt} width="640" height="420" loading="lazy" decoding="async" />
                  <div>
                    <h3>{airport.title}</h3>
                    <p><strong>Recommended:</strong> {airport.recommended}</p>
                    <p>{airport.time}</p>
                    <p><strong>Budget:</strong> {airport.budget}</p>
                    <p>{airport.route}</p>
                    <p>{airport.fare}</p>
                    <p>Total time {airport.total}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="bj-panel bj-side-section bj-important">
            <header class="bj-section-title">
              <h2>Important Information</h2>
            </header>
            <div class="bj-info-groups">
              {importantGroups.map((group) => {
                const Icon = group.Icon;
                return (
                  <section class="bj-info-group">
                    <span class="bj-info-icon" aria-hidden="true"><Icon size={21} /></span>
                    <div>
                      <h3>{group.title}</h3>
                      {group.kicker && <p class="bj-kicker">{group.kicker}</p>}
                      <ul>
                        {group.items.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                  </section>
                );
              })}
            </div>
          </section>
        </aside>
      </section>

      <section class="bj-container bj-bottom-cta" aria-label="Unlock complete Beijing guide">
        <div>
          <h2>Get the full Beijing guide in the Arrival Pack</h2>
          <p>Unlock the Arrival Pack to get the Beijing PDF, 2–3 day routes, food picks, transport notes, ticket reminders, hotel area notes, Chinese addresses, and backup notes.</p>
        </div>
        <div class="bj-cta-features" aria-label="Included guide details">
          {ctaFeatures.map(({ label, Icon }) => (
            <span><Icon size={24} /> {label}</span>
          ))}
        </div>
        <div class="bj-cta-action">
          <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">Unlock Arrival Pack - $9.90</a>
          <small>Instant access · Downloadable PDFs · Easy to use</small>
        </div>
      </section>
    </div>
  ) : isShanghai ? (
    <div class="beijing-guide shanghai-guide">
      <section class="bj-hero" aria-labelledby="shanghai-itinerary-title">
        <div class="bj-container bj-hero__inner">
