---

<BaseLayout
  title={`${city.name} 1-Day Itinerary for First-Time Visitors`}
  description={`A free ${city.name} 1-day itinerary for first-time visitors with simple timing, booking reminders, food notes, and backup planning.`}
  headerCtaLabel={isBeijing || isShanghai ? "Unlock All Guides - $9.90" : undefined}
>
  {isBeijing ? (
    <div class="beijing-guide">
      <section class="bj-hero" aria-labelledby="beijing-itinerary-title">
        <div class="bj-container bj-hero__inner">
          <div class="bj-hero__copy">
            <p class="bj-eyebrow">FREE 1-DAY GUIDE</p>
            <h1 id="beijing-itinerary-title">Beijing <span class="bj-nowrap">1-Day</span><br />Itinerary</h1>
            <p class="bj-subtitle">Classic Route × Local Food × Practical Tips</p>
            <p class="bj-lead">
              A simple, efficient route for first-time visitors. Experience the best of Beijing in one day.
            </p>
            <div class="bj-stat-row" aria-label="Route summary">
              {beijingStats.map(({ label, value, Icon }) => (
                <div class="bj-stat">
                  <span class="bj-stat__icon" aria-hidden="true"><Icon size={23} /></span>
                  <span>
                    <strong>{label}</strong>
                    <small>{value}</small>
                  </span>
                </div>
              ))}
            </div>
          </div>
          <div class="bj-hero__image">
            <img src="/images/cities/beijing-cover.jpg" alt="Forbidden City rooftops at sunset in Beijing" />
          </div>
        </div>
      </section>

      <section class="bj-container bj-prep-grid" aria-label="Before you go">
        {prepCards.map((card) => {
          const Icon = card.Icon;
          return (
            <article class={`bj-prep-card bj-prep-card--${card.variant}`}>
              <div class="bj-card-heading">
                <span aria-hidden="true"><Icon size={22} /></span>
                <h2>{card.title}</h2>
              </div>
              {card.columns && (
                <div class="bj-booking-columns">
                  {card.columns.map((column) => (
                    <div>
                      <h3>{column.title}</h3>
                      {column.lines.map((line) => <p>{line}</p>)}
                    </div>
                  ))}
                </div>
              )}
              {card.checks && (
                <ul class="bj-check-list">
                  {card.checks.map((item) => (
                    <li><Check size={15} /> {item}</li>
                  ))}
                </ul>
              )}
              {card.highlight && (
                <div class="bj-season">
                  <strong>{card.highlight}</strong>
                  <p>{card.text}</p>
                </div>
              )}
            </article>
          );
        })}
      </section>

      <section class="bj-container bj-main-grid" aria-label="Beijing one-day itinerary details">
        <article class="bj-panel bj-timeline-panel">
          <header class="bj-section-title bj-section-title--center">
            <h2>One-Day Itinerary <span>(Classic Route)</span></h2>
          </header>

          <div class="bj-timeline">
            {beijingStops.map((stop) => {
              const TransportIcon = stop.transport.Icon;
              return (
                <section class="bj-stop">
                  <div class="bj-stop__time">
                    <strong>{stop.time}</strong>
                    <span>-{stop.end}</span>
                  </div>
                  <div class="bj-stop__marker" aria-hidden="true">{stop.number}</div>
                  <div class="bj-stop__content">
                    <h3>{stop.title} {stop.suffix && <span>{stop.suffix}</span>}</h3>
                    {stop.description && <p>{stop.description}</p>}

                    {stop.route && (
                      <div class="bj-route-card">
                        <div class="bj-route-card__heading">
                          <strong>Suggested Route</strong>
                          <span>(Enter from Meridian Gate, Exit at North Gate)</span>
                        </div>
