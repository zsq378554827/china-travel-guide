---
import { ArrowRight } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAttractionsByCity } from "@data/attractions";
import { cities, type City } from "@data/cities";

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.id },
    props: { city },
  }));
}

type Props = {
  city: City;
};

const { city } = Astro.props;
const cityAttractions = getAttractionsByCity(city.id);

const timeline = [
  ["Morning", `Start with the main landmark cluster for ${city.name}. Keep transport simple and arrive early.`],
  ["Lunch", "Choose a nearby, low-detour food area instead of crossing the city at midday."],
  ["Afternoon", "Continue with the second must-see area and leave room for tickets, queues, or weather changes."],
  ["Evening", "Use a flexible option near your hotel area, riverfront, old street, or easy metro line."],
];
---

<BaseLayout
  title={`${city.name} 1-Day Itinerary for First-Time Visitors`}
  description={`A free ${city.name} 1-day itinerary for first-time visitors with simple timing, booking reminders, food notes, and backup planning.`}
>
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><a href={city.href}>Cities</a><span>/</span><span>{city.name} 1-Day Itinerary</span>
      </nav>
      <p class="eyebrow">Free 1-day guide</p>
      <h1>{city.name} 1-Day Itinerary for First-Time Visitors</h1>
      <p class="lead">
        A brief but actionable first-day route for visitors who want a simple plan before unlocking the complete current pack.
      </p>
      <div class="trust-row">
        <span class="pill">Who this is for: first-time visitors</span>
        <span class="pill">Transport style: simple metro / taxi</span>
        <span class="pill">Book before arrival: key attractions</span>
      </div>
      <div class="inline-actions">
        <a class="button button-primary" href="#free-route">Read the free route</a>
        <a class="button button-secondary" href={city.twoDayHref}>Preview paid multi-day routes</a>
      </div>
    </div>
  </section>

  <section class="section" id="free-route">
    <div class="container timeline">
      {timeline.map(([label, text]) => (
        <article class="timeline-item">
          <div>
            <h2>{label}</h2>
            <p class="muted">{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight">
    <div class="container content-grid">
      <article class="content-card">
        <h2>Before you go</h2>
        <ul class="clean-list">
          <li>Save your hotel address in Chinese.</li>
          <li>Check ticket booking windows and passport-name rules.</li>
          <li>Prepare Alipay or WeChat Pay with a backup payment method.</li>
        </ul>
      </article>
      <article class="content-card">
        <h2>Key attraction pages</h2>
        <ul class="clean-list">
          {cityAttractions.slice(0, 3).map((attraction) => (
            <li><a class="text-link" href={`/attractions/${attraction.slug}/`}>{attraction.name} <ArrowRight size={16} /></a></li>
          ))}
        </ul>
      </article>
      <article class="content-card">
        <h2>Backup plan</h2>
        <p class="muted">If tickets sell out, weather changes, or the day feels too long, switch to a slower city walk and keep the paid multi-day route for later.</p>
      </article>
      <article class="content-card">
        <h2>Want 2 more days planned?</h2>
        <p class="muted">The full current pack adds 2-day and 3-day routes, printable PDFs, city notes, food picks, and backup routes.</p>
        <a class="text-link" href="/unlock/">Unlock all current itinerary packs for $9.90 <ArrowRight size={16} /></a>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container paper-card unlock-panel">
      <div>
        <p class="eyebrow">Multi-day previews</p>
        <h2>Need more than one day in {city.name}?</h2>
        <p class="muted">
          Preview the paid 2-day and 3-day outlines before buying. Full timings, maps, food notes, booking reminders,
          and printable PDFs are in the current pack.
        </p>
      </div>
      <div class="setup-card">
        <ul class="clean-list">
          <li><a class="text-link" href={city.twoDayHref}>{city.name} 2-day preview <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href={city.threeDayHref}>{city.name} 3-day preview <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/china-ticket-booking-guide/">Ticket booking guide <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/china-public-transport-guide/">Public transport guide <ArrowRight size={16} /></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
