---
import {
  ArrowRight,
  Building2,
  CalendarDays,
  ClipboardCheck,
  FileText,
  Hotel,
  Info,
  Landmark,
  LockKeyhole,
  Map,
  MapPinned,
  Moon,
  Route,
  Star,
  TrainFront,
  Utensils,
} from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAttractionsByCity } from "@data/attractions";
import { cities, type City } from "@data/cities";
import { checkoutUrl } from "@data/site";

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.id },
    props: { city },
  }));
}

type Props = {
  city: City;
};

const { city } = Astro.props;
const cityAttractions = getAttractionsByCity(city.id);
const isBeijing = city.id === "beijing";
const isShanghai = city.id === "shanghai";
const isXian = city.id === "xian";
const isGuilinYangshuo = city.id === "guilin-yangshuo";

const beijingGuideCards = [
  {
    status: "free",
    title: "One-Day Itinerary",
    description: "Time-based route with transport tips and key stops.",
    image: "/images/cities/beijing-cover.jpg",
    alt: "Beijing landmarks and the Great Wall",
    href: "/cities/beijing/1-day-itinerary/",
    Icon: CalendarDays,
  },
  {
    status: "locked",
    title: "Food Guide",
    description: "Best local dishes and recommended areas.",
    image: "/images/beijing-itinerary/peking-duck-thumb.jpg",
    alt: "Peking duck and Beijing local food",
    Icon: Utensils,
  },
  {
    status: "locked",
    title: "Transport Guide",
    description: "Subway, bus, DiDi, walking, and ticket tips.",
    image: "/images/beijing-itinerary/beijing-airport-thumb.jpg",
    alt: "Beijing transport hub illustration",
    Icon: TrainFront,
  },
  {
    status: "locked",
    title: "Booking Reminders",
    description: "Tickets, ID, entry tips, and important notes.",
    image: "/images/cities/beijing-cover.jpg",
    alt: "Beijing attraction ticket booking reminder illustration",
    Icon: ClipboardCheck,
  },
  {
    status: "locked",
    title: "Quick Notes & Backup Plan",
    description: "Avoid crowds, adjust timing, and solve common issues.",
    image: "/images/cities/beijing-cover.jpg",
    alt: "Mutianyu Great Wall backup planning illustration",
    Icon: FileText,
  },
];

const beijingHighlights = [
  { label: "Forbidden City", Icon: Landmark },
  { label: "Temple of Heaven", Icon: Building2 },
  { label: "Mutianyu Great Wall", Icon: MapPinned },
  { label: "Local Food Experience", Icon: Utensils },
  { label: "Houhai / Night View", Icon: Moon },
];

const beijingPackFeatures = [
  { label: "2-3 Day Routes", Icon: Route },
  { label: "Food Map", Icon: Map },
  { label: "Transport Guide", Icon: TrainFront },
  { label: "Attraction Tips", Icon: Star },
  { label: "Hotel Area Notes", Icon: Hotel },
  { label: "Backup Plans", Icon: ClipboardCheck },
  { label: "Printable PDFs", Icon: FileText },
];

const shanghaiGuideCards = [
  {
    status: "free",
    title: "One-Day Itinerary",
    description: "Time-based route with transport tips and key stops.",
    image: "/images/cities/shanghai-cover.jpg",
    alt: "Shanghai skyline along the Huangpu River",
    href: "/cities/shanghai/1-day-itinerary/",
    Icon: CalendarDays,
  },
  {
    status: "locked",
    title: "Food Guide",
    description: "Best local dishes and recommended areas.",
    image: "/images/shanghai/food-xiaolongbao.jpg",
    alt: "Shanghai xiaolongbao and local dishes",
    Icon: Utensils,
  },
  {
    status: "locked",
    title: "Transport Guide",
    description: "Subway, bus, DiDi, walking, and ticket tips.",
    image: "/images/shanghai/airport-pvg.jpg",
    alt: "Shanghai transport hub illustration",
    Icon: TrainFront,
  },
  {
    status: "locked",
    title: "Booking Reminders",
    description: "Tickets, ID, entry tips, and important notes.",
    image: "/images/shanghai/shanghai-hero-bund.jpg",
    alt: "Shanghai attraction booking reminder illustration",
    Icon: ClipboardCheck,
  },
  {
    status: "locked",
    title: "Quick Notes & Backup Plan",
    description: "Avoid crowds, adjust timing, and solve common issues.",
    image: "/images/cities/shanghai-cover.jpg",
    alt: "Shanghai night skyline backup planning illustration",
    Icon: FileText,
  },
];

const shanghaiHighlights = [
  { label: "The Bund", Icon: Building2 },
  { label: "Yu Garden", Icon: Landmark },
  { label: "Shanghai Tower / Lujiazui View", Icon: MapPinned },
  { label: "Local Food Experience", Icon: Utensils },
  { label: "Huangpu River Night View", Icon: Moon },
];

const xianGuideCards = [
  {
    status: "free",
    title: "One-Day Itinerary",
    description: "Time-based route with transport tips and key stops.",
    image: "/images/cities/xian-cover.jpg",
    imagePosition: "center center",
    alt: "Terracotta Warriors and Xi'an ancient city wall at sunset",
    href: "/cities/xian/1-day-itinerary/",
    Icon: CalendarDays,
  },
  {
    status: "locked",
    title: "Food Guide",
    description: "Best local dishes and recommended areas.",
    image: "/images/beijing-itinerary/zhajiangmian-thumb.jpg",
    imagePosition: "center center",
    alt: "Local noodle dish representing Xi'an food guide",
    Icon: Utensils,
  },
  {
    status: "locked",
    title: "Transport Guide",
    description: "Subway, bus, DiDi, walking, and ticket tips.",
    image: "/images/cities/xian-cover.jpg",
    imagePosition: "72% center",
    alt: "Xi'an ancient city wall transport planning image",
    Icon: TrainFront,
  },
  {
    status: "locked",
    title: "Booking Reminders",
    description: "Tickets, ID, entry tips, and important notes.",
    image: "/images/cities/xian-cover.jpg",
    imagePosition: "82% center",
    alt: "Xi'an city wall and attraction booking reminder image",
    Icon: ClipboardCheck,
  },
  {
    status: "locked",
    title: "Quick Notes & Backup Plan",
    description: "Avoid crowds, adjust timing, and solve common issues.",
    image: "/images/cities/xian-cover.jpg",
    imagePosition: "35% center",
    alt: "Xi'an sunset scene for backup planning notes",
    Icon: FileText,
  },
];

const xianHighlights = [
  { label: "Terracotta Warriors", Icon: Landmark },
  { label: "Ancient City Wall", Icon: Building2 },
  { label: "Bell & Drum Tower", Icon: MapPinned },
  { label: "Local Food Experience", Icon: Utensils },
  { label: "Muslim Quarter Night View", Icon: Moon },
];

const guilinYangshuoGuideCards = [
  {
    status: "free",
    title: "One-Day Itinerary",
    description: "Time-based route with transport tips and key stops.",
    image: "/images/cities/guilin-yangshuo-cover.jpg",
    imagePosition: "center center",
    alt: "Li River karst landscape near Guilin and Yangshuo",
    href: "/cities/guilin-yangshuo/1-day-itinerary/",
    Icon: CalendarDays,
  },
  {
    status: "locked",
    title: "Food Guide",
    description: "Best local dishes and recommended areas.",
    image: "/images/shanghai/food-shanghai-dinner.jpg",
    imagePosition: "center center",
    alt: "Local food representing Guilin and Yangshuo food guide",
    Icon: Utensils,
  },
  {
    status: "locked",
    title: "Transport Guide",
    description: "Cruise pier, taxi, railway station, and Yangshuo transfer tips.",
    image: "/images/cities/guilin-yangshuo-cover.jpg",
    imagePosition: "58% center",
    alt: "Li River and Yangshuo transfer planning image",
    Icon: TrainFront,
  },
  {
    status: "locked",
    title: "Booking Reminders",
    description: "Tickets, pier notes, entry tips, and important notes.",
    image: "/images/cities/guilin-yangshuo-cover.jpg",
    imagePosition: "44% center",
    alt: "Guilin and Yangshuo cruise booking reminder image",
    Icon: ClipboardCheck,
  },
  {
    status: "locked",
    title: "Quick Notes & Backup Plan",
    description: "Avoid crowds, adjust timing, and solve common issues.",
    image: "/images/cities/guilin-yangshuo-cover.jpg",
    imagePosition: "76% center",
    alt: "Yangshuo riverside evening backup planning image",
    Icon: FileText,
  },
];

const guilinYangshuoHighlights = [
  { label: "Li River Cruise", Icon: Landmark },
  { label: "Yulong River", Icon: MapPinned },
  { label: "Ten-Mile Gallery", Icon: Route },
  { label: "Local Food Experience", Icon: Utensils },
  { label: "West Street / Riverside Night View", Icon: Moon },
];

const cityEntryConfig = isBeijing
  ? {
      headerCtaLabel: "Unlock - $9.90",
      pageClass: "",
      showIllustrationLabels: false,
      heroAlt: city.imageAlt,
      breadcrumbName: "Beijing",
      region: "NORTH CHINA",
      title: "Beijing",
      subtitle: "Imperial landmarks, hutongs,\nand the Great Wall.",
      mustSee: "Forbidden City, Temple of Heaven, Mutianyu Great Wall",
      primaryHref: "/cities/beijing/1-day-itinerary/",
      unlockLabel: "Unlock Full Beijing Pack - $9.90",
      guideCards: beijingGuideCards,
      lockedPackName: "Full Beijing Pack",
      hint: "Click any locked guide to see what’s included in the Full Beijing Pack.",
      highlights: beijingHighlights,
      fullPackTitle: "Want the Full Beijing Pack?",
      fullPackText:
        "Get the full Beijing plan with extra day routes, food picks, transport notes, hotel area notes, attraction tips, backup plans, and printable PDFs.",
      packFeatures: beijingPackFeatures,
    }
  : isShanghai
    ? {
        headerCtaLabel: "Unlock Pack - $9.90",
        pageClass: "beijing-city-page--shanghai",
        showIllustrationLabels: false,
        heroAlt: "Shanghai skyline along the Huangpu River",
        breadcrumbName: "Shanghai",
        region: "EAST CHINA",
        title: "Shanghai",
        subtitle: "Modern skyline, historic charm,\nand world-class food.",
        mustSee: "The Bund, Yu Garden, Lujiazui Skyline",
        primaryHref: "/cities/shanghai/1-day-itinerary/",
        unlockLabel: "Unlock Full Shanghai Pack - $9.90",
        guideCards: shanghaiGuideCards,
        lockedPackName: "Full Shanghai Pack",
        hint: "Click any locked guide to see what’s included in the Full Shanghai Pack.",
        highlights: shanghaiHighlights,
        fullPackTitle: "Want the Full Shanghai Pack?",
        fullPackText:
          "Get the full Shanghai plan with extra day routes, food picks, transport notes, hotel area notes, attraction tips, backup plans, and printable PDFs.",
        packFeatures: beijingPackFeatures,
      }
    : isXian
      ? {
          headerCtaLabel: "Unlock Pack - $9.90",
          pageClass: "beijing-city-page--xian",
          showIllustrationLabels: false,
          heroAlt: "Terracotta Warriors and Xi'an ancient city wall at sunset",
          heroPosition: "center center",
          breadcrumbName: "Xi’an",
          region: "NORTHWEST CHINA",
          title: "Xi’an",
          subtitle: "Ancient capital, Terracotta Warriors,\nand rich Silk Road heritage.",
          mustSee: "Terracotta Warriors, Ancient City Wall, Bell & Drum Tower",
          primaryHref: "/cities/xian/1-day-itinerary/",
          unlockLabel: "Unlock Full Xi’an Pack - $9.90",
          guideCards: xianGuideCards,
          lockedPackName: "Full Xi’an Pack",
          hint: "Click any locked guide to see what’s included in the Full Xi’an Pack.",
          highlights: xianHighlights,
          fullPackTitle: "Want the Full Xi’an Pack?",
          fullPackText:
            "Get the full Xi’an plan with extra day routes, food picks, transport notes, hotel area notes, attraction tips, backup plans, and printable PDFs.",
          packFeatures: beijingPackFeatures,
        }
      : isGuilinYangshuo
        ? {
            headerCtaLabel: "Unlock Pack - $9.90",
            pageClass: "beijing-city-page--guilin-yangshuo",
            showIllustrationLabels: false,
            heroAlt: "Li River karst landscape near Guilin and Yangshuo",
            heroPosition: "center center",
            breadcrumbName: "Guilin & Yangshuo",
            region: "SOUTH CHINA",
            title: "Guilin & Yangshuo",
            subtitle: "Li River, Yulong River, and\nstunning karst landscapes.",
            mustSee: "Li River Cruise, Yulong River, Yangshuo West Street",
            primaryHref: "/cities/guilin-yangshuo/1-day-itinerary/",
            unlockLabel: "Unlock Full Guilin & Yangshuo Pack - $9.90",
            guideCards: guilinYangshuoGuideCards,
            lockedPackName: "Full Guilin & Yangshuo Pack",
            hint: "Click any locked guide to see what’s included in the Full Guilin & Yangshuo Pack.",
            highlights: guilinYangshuoHighlights,
            fullPackTitle: "Want the Full Guilin & Yangshuo Pack?",
            fullPackText:
              "Get the full Guilin & Yangshuo plan with extra day routes, food picks, transport notes, hotel area notes, attraction tips, backup plans, and printable PDFs.",
            packFeatures: beijingPackFeatures,
          }
        : null;

const cityEntrySubtitleLines = cityEntryConfig?.subtitle.split("\n") ?? [];
---

<BaseLayout
  title={`${city.name} Travel Guide for First-Time Visitors`}
  description={`${city.name} first-time visitor overview with free 1-day guide, must-see spots, practical tips, and full pack preview.`}
  headerCtaLabel={cityEntryConfig?.headerCtaLabel}
>
  {cityEntryConfig ? (
    <div class={`beijing-city-page ${cityEntryConfig.pageClass}`}>
      <section class="beijing-city-hero" aria-labelledby="beijing-city-title">
        <img
          class="beijing-city-hero__image"
          src={city.image}
          alt={cityEntryConfig.heroAlt}
          style={`object-position: ${cityEntryConfig.heroPosition ?? city.imagePosition ?? "center center"}`}
        />
        <div class="beijing-city-hero__scrim" aria-hidden="true"></div>
        <div class="container beijing-city-hero__inner">
          <nav class="beijing-city-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a><span>/</span><a href="/#cities">Cities</a><span>/</span><span>{cityEntryConfig.breadcrumbName}</span>
          </nav>
          <p class="beijing-city-region">{cityEntryConfig.region}</p>
          <h1 id="beijing-city-title">{cityEntryConfig.title}</h1>
          <p class="beijing-city-lead">
            {cityEntrySubtitleLines.map((line, index) => (
              <>{line}{index < cityEntrySubtitleLines.length - 1 && <><br />{" "}</>}</>
            ))}
          </p>
          <div class="beijing-city-pills" aria-label={`${cityEntryConfig.title} route summary`}>
            <span>Recommended: Full day</span>
            <span>Best for: First-time visitors</span>
            <span>Must-see: {cityEntryConfig.mustSee}</span>
          </div>
          <div class="beijing-city-actions">
            <a class="button button-primary beijing-city-primary" href={cityEntryConfig.primaryHref}>Read the free 1-day guide</a>
            <a class="button beijing-city-secondary" href={checkoutUrl} data-analytics-event="checkout_click">{cityEntryConfig.unlockLabel}</a>
          </div>
          {cityEntryConfig.showIllustrationLabels && <span class="illustration-label">Illustration</span>}
        </div>
      </section>

      <section class="beijing-guide-section" aria-labelledby="beijing-guide-cards-title">
        <div class="container">
          <div class="beijing-section-heading">
            <h2 id="beijing-guide-cards-title">Explore the Free 1-Day Guide</h2>
            <p>Only the 1-day itinerary is free. The other guides are included in the full pack.</p>
          </div>
          <div class="beijing-guide-grid">
            {cityEntryConfig.guideCards.map((card) => {
              const Icon = card.Icon;
              const isFree = card.status === "free";
              const href = isFree ? card.href : "#full-pack";
              const imagePosition = "imagePosition" in card ? card.imagePosition : "center center";
              return (
                <a
                  class={`beijing-guide-card ${isFree ? "beijing-guide-card--free" : "beijing-guide-card--locked"}`}
                  href={href}
                  data-analytics-event={isFree ? "city_click" : "unlock_click"}
                  aria-label={isFree ? `Open ${card.title}` : `${card.title} is included in the ${cityEntryConfig.lockedPackName}`}
                >
                  <div class="beijing-guide-card__image">
                    <img
                      src={card.image}
                      alt={card.alt}
                      loading="lazy"
                      decoding="async"
                      style={`object-position: ${imagePosition}`}
                    />
                    <span class={isFree ? "beijing-card-badge beijing-card-badge--free" : "beijing-card-badge beijing-card-badge--lock"}>
                      {isFree ? "FREE" : <LockKeyhole size={18} />}
                    </span>
                    {cityEntryConfig.showIllustrationLabels && <span class="illustration-label illustration-label--card">Illustration</span>}
                  </div>
                  <div class="beijing-guide-card__body">
                    <Icon size={26} />
                    <h3>{card.title}</h3>
                    <p>{card.description}</p>
                    <span class={isFree ? "beijing-guide-card__action" : "beijing-guide-card__action beijing-guide-card__action--locked"}>
                      {isFree ? <>Open free guide <ArrowRight size={18} /></> : <><LockKeyhole size={15} /> Included in Full Pack</>}
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
          <p class="beijing-card-hint"><Info size={17} /> {cityEntryConfig.hint}</p>
        </div>
      </section>

      <section class="beijing-highlights" aria-labelledby="beijing-highlights-title">
        <div class="container">
          <div class="beijing-highlight-card">
            <div class="beijing-highlight-card__heading">
              <h2 id="beijing-highlights-title">Core Highlights in This Route</h2>
              <p>A full-day route with an early start.</p>
            </div>
            <div class="beijing-highlight-list">
              {cityEntryConfig.highlights.map(({ label, Icon }) => (
                <div class="beijing-highlight-item">
                  <span><Icon size={36} /></span>
                  <strong>{label}</strong>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="beijing-full-pack" id="full-pack" aria-labelledby="beijing-full-pack-title">
        <div class="container">
          <div class="beijing-full-pack__panel">
            <div class="beijing-full-pack__copy">
              <h2 id="beijing-full-pack-title">{cityEntryConfig.fullPackTitle}</h2>
              <p>{cityEntryConfig.fullPackText}</p>
            </div>
            <div class="beijing-pack-features" aria-label={`${cityEntryConfig.lockedPackName} includes`}>
              {cityEntryConfig.packFeatures.map(({ label, Icon }) => (
                <span><Icon size={26} /> {label}</span>
              ))}
            </div>
            <div class="beijing-full-pack__action">
              <a class="button button-primary" href={checkoutUrl} data-analytics-event="checkout_click">{cityEntryConfig.unlockLabel}</a>
              <small>Instant access · Printable PDFs · Easy to use</small>
            </div>
          </div>
        </div>
      </section>
    </div>
  ) : (
    <>
      <section class="subpage-hero">
        <div class="container subpage-hero__inner">
          <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Cities</span><span>/</span><span>{city.name}</span></nav>
          <p class="eyebrow">{city.region}</p>
          <h1>{city.name}</h1>
          <p class="lead">{city.tagline}</p>
          <div class="trust-row">
            <span class="pill">Recommended: {city.recommendedDays}</span>
            <span class="pill">Must-see: {city.mustSee}</span>
          </div>
          <div class="inline-actions">
            <a class="button button-primary" href={city.freeGuideHref}>Read the free 1-day guide</a>
            <a class="button button-secondary" href={city.twoDayHref}>Preview 2-day / 3-day</a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container content-grid">
          <article class="content-card">
            <MapPinned size={32} />
            <h2>Must-see spots</h2>
            <ul class="clean-list">
              {cityAttractions.slice(0, 4).map((attraction) => (
                <li><a class="text-link" href={`/attractions/${attraction.slug}/`}>{attraction.name} <ArrowRight size={16} /></a></li>
              ))}
            </ul>
          </article>
          <article class="content-card">
            <ArrowRight size={32} />
            <h2>Free 1-Day Guide</h2>
            <p class="muted">A simple route for first-time visitors with booking reminders and backup notes.</p>
            <a class="text-link" href={city.freeGuideHref}>Open free guide <ArrowRight size={16} /></a>
          </article>
          <article class="content-card">
            <LockKeyhole size={32} />
            <h2>2-Day / 3-Day previews</h2>
            <p class="muted">Preview the paid route structure before unlocking the full current pack.</p>
            <div class="tag-list" style="margin-top: 12px;">
              <a class="tag" href={city.twoDayHref}>2-day preview</a>
              <a class="tag" href={city.threeDayHref}>3-day preview</a>
              <a class="tag" href="/unlock/">Full pack</a>
            </div>
          </article>
        </div>
      </section>

      <section class="section-tight">
        <div class="container content-grid">
          <article class="content-card">
            <h2>Before you arrive</h2>
            <p class="muted">Set up payments, transport, apps, and ticket backups before you rely on them during the day.</p>
            <a class="text-link" href="/china-travel-checklist/">Open arrival checklist <ArrowRight size={16} /></a>
          </article>
          <article class="content-card">
            <h2>Ticket reminders</h2>
            <p class="muted">Major attractions can require passport-based booking and saved confirmation screens.</p>
            <a class="text-link" href="/china-ticket-booking-guide/">Read ticket booking guide <ArrowRight size={16} /></a>
          </article>
          <article class="content-card">
            <h2>Unlock current pack</h2>
            <p class="muted">Get complete 2-day and 3-day city routes, printable PDFs, booking reminders, and backup plans.</p>
            <a class="text-link" href="/unlock/">Preview all current packs <ArrowRight size={16} /></a>
          </article>
        </div>
      </section>
    </>
  )}
</BaseLayout>

<style>
  .beijing-city-page {
    --city-red: #c52222;
    --city-red-dark: #a91414;
    --city-green: #1f7a57;
    --city-ink: #17130f;
    --city-muted: #5f574e;
    --city-line: rgba(118, 96, 68, 0.2);
    background: linear-gradient(180deg, #fffaf2 0%, #fbf7f0 48%, #f8f2e9 100%);
    color: var(--city-ink);
  }

  .beijing-city-hero {
    position: relative;
    min-height: 590px;
    overflow: hidden;
    color: #fffaf2;
  }

  .beijing-city-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .beijing-city-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(10, 12, 10, 0.78) 0%, rgba(12, 14, 11, 0.55) 34%, rgba(12, 14, 11, 0.18) 62%, rgba(12, 14, 11, 0.02) 100%),
      linear-gradient(180deg, rgba(15, 14, 12, 0.28) 0%, rgba(15, 14, 12, 0.06) 40%, rgba(15, 14, 12, 0.38) 100%);
  }

  .beijing-city-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 590px;
    flex-direction: column;
    justify-content: center;
    padding: 34px 0 44px;
  }

  .beijing-city-breadcrumb {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 42px;
    color: rgba(255, 250, 242, 0.9);
    font-size: 0.92rem;
    font-weight: 650;
  }

  .beijing-city-breadcrumb a:hover {
    color: #fff;
  }

  .beijing-city-region {
    margin: 0 0 14px;
    color: #7de0ad;
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.08em;
  }

  .beijing-city-hero h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(5rem, 8vw, 7.8rem);
    line-height: 0.88;
    text-shadow: 0 7px 24px rgba(0, 0, 0, 0.36);
  }

  .beijing-city-page--guilin-yangshuo .beijing-city-hero h1 {
    font-size: clamp(4.4rem, 6.2vw, 6.7rem);
  }

