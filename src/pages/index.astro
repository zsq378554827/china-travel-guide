---
import {
  CalendarDays,
  ClipboardCheck,
  CreditCard,
  FileText,
  LayoutGrid,
  Phone,
  ShieldAlert,
  ShieldCheck,
  Ticket,
  TrainFront,
  Utensils,
  Wifi,
} from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import CityCard from "@components/CityCard.astro";
import GuideMockup from "@components/GuideMockup.astro";
import HomeHero3D from "@components/home/HomeHero3D.astro";
import { cities } from "@data/cities";
import { checkoutUrl, resolvedSiteUrl, site } from "@data/site";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  description: site.description,
  url: resolvedSiteUrl,
};

const prepCards = [
  {
    title: "Arrival Checklist",
    subtitle: "What to prepare",
    href: "/arrival-checklist/",
    Icon: ClipboardCheck,
  },
  {
    title: "Payment & Internet",
    subtitle: "Payment & internet options",
    href: "/travel-prep/payment-internet/",
    Icon: Wifi,
  },
  {
    title: "Transport & Tickets",
    subtitle: "Getting around & tickets",
    href: "/travel-prep/transport-tickets/",
    Icon: TrainFront,
  },
  {
    title: "Travel Apps",
    subtitle: "Useful apps you’ll need",
    href: "/china-travel-apps/",
    Icon: Phone,
  },
  {
    title: "Emergency Help",
    subtitle: "Emergency contacts and common issues",
    href: "/china-travel-checklist/#emergency",
    Icon: ShieldAlert,
  },
  {
    title: "Offline PDF Pack",
    subtitle: "Download & print anytime",
    href: "/unlock/",
    Icon: FileText,
  },
];

const packItems = [
  { title: "1 / 2 / 3-Day Routes", subtitle: "Six cities", Icon: CalendarDays },
  { title: "Local Food Picks", subtitle: "With addresses", Icon: Utensils },
  { title: "Attraction Ticket Guide", subtitle: "Step-by-step", Icon: Ticket },
  { title: "Arrival Checklist", subtitle: "What to prepare", Icon: ClipboardCheck },
  { title: "Payment & Internet", subtitle: "Ways to pay & connect", Icon: CreditCard },
  { title: "Transport & Tickets", subtitle: "Getting around", Icon: TrainFront },
  { title: "Travel Apps", subtitle: "Must-have apps", Icon: LayoutGrid },
  { title: "Emergency Help", subtitle: "Contacts & tips", Icon: ShieldCheck },
  { title: "Offline PDF", subtitle: "Printable & offline", Icon: FileText },
];
---

<BaseLayout
  title="China Travel Guides for First-Time Visitors"
  description="Free city guides, arrival checklists, practical tips, and printable resources for first-time visitors to China."
  jsonLd={jsonLd}
  headerCtaLabel="Unlock Pack · $9.90"
>
  <HomeHero3D />

  <section class="section home-city-section" id="cities">
    <div class="container">
      <div class="section-heading">
        <div>
          <h2>Browse Free City Guides.</h2>
        </div>
        <p class="muted">
          First-time traveler favorites: Beijing, Shanghai, Xi’an, Chengdu, Zhangjiajie, Guilin / Yangshuo.
        </p>
      </div>
      <div class="city-grid">
        {cities.map((city) => <CityCard city={city} />)}
      </div>
    </div>
  </section>

  <section class="section-tight" id="travel-prep">
    <div class="container travel-prep-panel">
      <div class="travel-prep-copy">
        <p class="eyebrow">Travel Prep Hub</p>
        <h2>Put the most common arrival questions in one place.</h2>
        <p class="muted">
          Payment, internet, transport, apps, and emergencies — get ready before you land.
        </p>
      </div>
      <div class="travel-prep-grid" aria-label="Travel prep links">
        {prepCards.map(({ title, subtitle, href, Icon }) => (
          <a class="travel-prep-card" href={href}>
            <Icon size={32} stroke-width={2.1} />
            <strong>{title}</strong>
            <span>{subtitle}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="arrival-pack">
    <div class="container arrival-pack-panel">
      <div class="arrival-pack-mockup">
        <p class="eyebrow">Arrival Pack</p>
        <GuideMockup compact />
      </div>

      <div class="arrival-pack-includes">
        <div class="arrival-pack-heading">
          <span></span>
          <strong>You’ll Get</strong>
          <span></span>
        </div>
        <div class="arrival-pack-grid" aria-label="Arrival Pack includes">
          {packItems.map(({ title, subtitle, Icon }) => (
            <div class="arrival-pack-item">
              <Icon size={26} />
              <strong>{title}</strong>
              <span>{subtitle}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="arrival-pack-checkout">
        <p class="arrival-pack-kicker">First-time visitors — get the essentials in one pack.</p>
        <p class="price">$9.90 <span>USD</span></p>
        <div class="trust-row">
          <span class="pill">One-time purchase</span>
          <span class="pill">No subscription</span>
          <span class="pill">Printable PDF</span>
          <span class="pill">1 / 2 / 3-day routes</span>
        </div>
        <a class="button button-primary arrival-pack-button" href={checkoutUrl} data-analytics-event="checkout_click">
          Unlock Arrival Pack Now
        </a>
        <small>Secure payment · Instant access · Use anytime</small>
      </div>
    </div>
  </section>
</BaseLayout>
