---
import { ArrowRight, ClipboardCheck, CloudDownload, FileText, MapPinned } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const startHereFiles = ["How to Use This Pack PDF", "Arrival Checklist PDF"];

const cityPackFiles = [
  "Beijing City Pack PDF",
  "Shanghai City Pack PDF",
  "Xi’an City Pack PDF",
  "Chengdu City Pack PDF",
  "Zhangjiajie City Pack PDF",
  "Guilin & Yangshuo City Pack PDF",
];

const travelPrepFiles = [
  "Arrival Checklist PDF",
  "Payment & Internet Checklist PDF",
  "Transport & Tickets Checklist PDF",
  "Travel Apps Checklist PDF",
  "Emergency Help Card PDF",
];
---

<BaseLayout
  title="Your Arrival Pack"
  description="Download center structure for the Arrival Pack."
  headerCtaLabel="Unlock Pack - $9.90"
>
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Success</span></nav>
      <p class="eyebrow">Purchase complete</p>
      <h1>Your Arrival Pack</h1>
      <p class="lead">
        Thank you for unlocking the Arrival Pack. Download only what you need for your trip.
      </p>
      <div class="inline-actions">
        <a class="button button-primary" href="#city-pack-pdfs">View city PDFs</a>
        <a class="button button-secondary" href="/arrival-checklist/">Open arrival checklist</a>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Start Here</p>
          <h2>Open these first.</h2>
        </div>
      </div>
      <div class="content-grid">
        {startHereFiles.map((title) => (
          <article class="content-card">
            <ClipboardCheck size={32} />
            <h3>{title}</h3>
            <p class="muted">Use the secure Gumroad download link from your purchase email to access this file.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight" id="city-pack-pdfs">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">City Pack PDFs</p>
          <h2>Download the city files you need.</h2>
        </div>
      </div>
      <div class="content-grid">
        {cityPackFiles.map((title) => (
          <article class="content-card">
            <MapPinned size={32} />
            <h3>{title}</h3>
            <p class="muted">Includes 1 / 2 / 3-day routes, food picks, transport notes, ticket reminders, hotel area notes, Chinese addresses, and quick backup notes.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Travel Prep Printables</p>
          <h2>Use these as short offline checklists.</h2>
        </div>
      </div>
      <div class="content-grid">
        {travelPrepFiles.map((title) => (
          <article class="content-card">
            <FileText size={32} />
            <h3>{title}</h3>
            <p class="muted">Save or print this checklist before departure.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container paper-card unlock-panel">
      <div>
        <p class="eyebrow">Download access</p>
        <h2>Use your Gumroad receipt for secure files.</h2>
        <p class="muted">
          The public success page lists the Arrival Pack structure. Actual file delivery is handled by Gumroad through
          your checkout page and purchase email.
        </p>
      </div>
      <div class="setup-card">
        <ul class="clean-list">
          <li><a class="text-link" href="/#cities">Explore free city guides <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/travel-prep/payment-internet/">Read payment setup <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/unlock/">Return to Arrival Pack page <CloudDownload size={16} /></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
