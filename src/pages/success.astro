---
import { ArrowRight, CloudDownload, MailCheck, ShieldCheck } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Purchase Success"
  description="Download instructions and delivery notes for the China First-Time Visitor Pack after checkout."
>
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Success</span></nav>
      <p class="eyebrow">Checkout return</p>
      <h1>Your China travel pack order is being processed.</h1>
      <p class="lead">
        This page is reserved for the payment provider success redirect. Before launch, connect the checkout provider,
        delivery email, and secure download link.
      </p>
      <div class="inline-actions">
        <a class="button button-primary" href="/unlock/">Return to pack page</a>
        <a class="button button-secondary" href="/china-travel-checklist/">Open free checklist</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content-grid">
      <article class="content-card">
        <CloudDownload size={32} />
        <h2>Download delivery</h2>
        <p class="muted">The production version should show or email the secure PDF download link generated by Lemon Squeezy, Gumroad, or the chosen provider.</p>
      </article>
      <article class="content-card">
        <MailCheck size={32} />
        <h2>Email backup</h2>
        <p class="muted">Use the same email entered at checkout. Keep a duplicate delivery email for download problems and duplicate-purchase support.</p>
      </article>
      <article class="content-card">
        <ShieldCheck size={32} />
        <h2>Launch checklist</h2>
        <ul class="clean-list">
          <li>Configure PUBLIC_CHECKOUT_URL</li>
          <li>Configure payment provider success redirect to /success/</li>
          <li>Test file delivery before taking live payments</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container paper-card unlock-panel">
      <div>
        <p class="eyebrow">Need help before launch?</p>
        <h2>Use the free pages until checkout is connected.</h2>
        <p class="muted">The public MVP can still collect SEO traffic with free city and setup pages while the payment flow is being connected.</p>
      </div>
      <div class="setup-card">
        <ul class="clean-list">
          <li><a class="text-link" href="/#cities">Explore free city guides <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/china-travel-checklist/">Read the arrival checklist <ArrowRight size={16} /></a></li>
          <li><a class="text-link" href="/how-to-pay-in-china/">Read payment setup guide <ArrowRight size={16} /></a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
