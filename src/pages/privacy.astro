---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy" description="Privacy policy for the China Travel Guide MVP.">
  <section class="subpage-hero">
    <div class="container subpage-hero__inner">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><span>Privacy</span></nav>
      <h1>Privacy Policy</h1>
      <p class="lead">This MVP does not collect account data. Analytics, checkout, and email tools must be documented here before launch.</p>
    </div>
  </section>
  <section class="section">
    <div class="container content-card">
      <h2>Current MVP state</h2>
      <p class="muted">
        No login, comments, newsletter form, or self-hosted checkout is active. If Google Analytics, Search Console,
        Lemon Squeezy, Gumroad, or other third-party services are added, this page must be updated before launch.
      </p>
    </div>
  </section>
</BaseLayout>
